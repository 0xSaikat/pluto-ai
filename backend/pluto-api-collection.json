          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/api/projects",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_name\": \"Pluto AI Web Platform\",\n  \"description\": \"Security analysis for our CSE4104 course project\"\n}"
            }
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{baseUrl}}/api/projects"
          }
